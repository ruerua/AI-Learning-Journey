    "import numpy as np\n",
    "\n",
    "# 创建一个一维数组\n",
    "arr1 = np.array([1, 2, 3, 4, 5])\n",
    "print(\"一维数组:\", arr1)\n",
    "\n",
    "# 创建一个全零数组\n",
    "zeros = np.zeros((3, 3))\n",
    "print(\"\\n全零数组:\\n\", zeros)\n",
    "\n",
    "# 创建一个随机数组\n",
    "random_arr = np.random.randn(2, 3)\n",
    "print(\"\\n随机数组:\\n\", random_arr)"
   ]
